{
  "name": "@showad/node-sdk",
  "version": "1.0.0",
  "description": "ShowAd SDK for Node.js (Express, Fastify, NestJS) - Protect your content with video ad verification",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.mjs",
      "require": "./dist/express.js"
    },
    "./fastify": {
      "types": "./dist/fastify.d.ts",
      "import": "./dist/fastify.mjs",
      "require": "./dist/fastify.js"
    },
    "./nestjs": {
      "types": "./dist/nestjs.d.ts",
      "import": "./dist/nestjs.mjs",
      "require": "./dist/nestjs.js"
    },
    "./access-policy": {
      "types": "./dist/access-policy.d.ts",
      "import": "./dist/access-policy.mjs",
      "require": "./dist/access-policy.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "fastify": ">=4.0.0",
    "@nestjs/common": ">=9.0.0",
    "@nestjs/core": ">=9.0.0",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "fastify": { "optional": true },
    "@nestjs/common": { "optional": true },
    "@nestjs/core": { "optional": true },
    "rxjs": { "optional": true }
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.2",
    "express": "^4.19.2",
    "fastify": "^4.28.1",
    "rxjs": "^7.8.1",
    "supertest": "^7.0.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "showad",
    "node",
    "express",
    "fastify",
    "nestjs",
    "sdk",
    "video-ads",
    "content-protection",
    "monetization"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/proofmark/showad-node-sdk"
  },
  "author": "ProofMark"
}
