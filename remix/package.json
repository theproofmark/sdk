{
  "name": "@showad/remix",
  "version": "1.0.0",
  "description": "ShowAd SDK for Remix and React Router v7 - protect content with video ad verification",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./access-policy": {
      "types": "./dist/access-policy.d.ts",
      "import": "./dist/access-policy.mjs",
      "require": "./dist/access-policy.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test \"tests/**/*.test.mjs\""
  },
  "peerDependencies": {
    "@remix-run/node": ">=2.0.0",
    "@remix-run/server-runtime": ">=2.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@remix-run/node": { "optional": true },
    "@remix-run/server-runtime": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "showad",
    "remix",
    "react-router",
    "sdk",
    "video-ads",
    "content-protection",
    "monetization"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/proofmark/showad-remix-sdk"
  },
  "author": "ProofMark"
}
