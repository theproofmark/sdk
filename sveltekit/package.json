{
  "name": "@showad/sveltekit",
  "version": "1.0.0",
  "description": "ShowAd SDK for SvelteKit - Protect content with video ad verification via a hooks.server.ts handle",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./access-policy": {
      "types": "./dist/access-policy.d.ts",
      "import": "./dist/access-policy.mjs",
      "require": "./dist/access-policy.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@sveltejs/kit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "showad",
    "sveltekit",
    "svelte",
    "sdk",
    "video-ads",
    "content-protection",
    "monetization"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/proofmark/showad-sveltekit-sdk"
  },
  "author": "ProofMark"
}
