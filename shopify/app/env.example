# Shopify Partner credentials (from your app in https://partners.shopify.com)
SHOPIFY_API_KEY=your_app_client_id
SHOPIFY_API_SECRET=your_app_client_secret
SHOPIFY_APP_URL=https://your-tunnel-or-host.example.com
SCOPES=write_products,read_themes

# ProofMark ShowAd credentials (per-shop overrides via the embedded admin take precedence)
SHOWAD_API_KEY=sk-your-default-api-key
SHOWAD_REDIRECT_SECRET=your-default-redirect-secret
SHOWAD_CREATOR_HASH=your-default-creator-hash
SHOWAD_API_URL=https://ad.proofmark.io
SHOWAD_VIDEO_URL=https://showad.proofmark.io

# Database (sqlite by default; switch to Postgres in production)
DATABASE_URL=file:./dev.sqlite

# Optional — encrypts API key + redirect secret at rest in the shop config table.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SHOWAD_CONFIG_ENCRYPTION_KEY=
