{
  "name": "@showad/nuxt",
  "version": "1.0.0",
  "description": "ShowAd Nuxt 3 module - Protect content with video ad verification",
  "repository": {
    "type": "git",
    "url": "https://github.com/proofmark/showad-nuxt-sdk"
  },
  "license": "MIT",
  "author": "ProofMark",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./module": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "test": "node test/access-policy.test.mjs && node test/module.test.mjs"
  },
  "keywords": [
    "showad",
    "nuxt",
    "nuxt-module",
    "sdk",
    "video-ads",
    "content-protection",
    "monetization"
  ],
  "dependencies": {
    "@nuxt/kit": "^3.13.0",
    "defu": "^6.1.4"
  },
  "peerDependencies": {
    "nuxt": "^3.13.0 || ^4.0.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^0.8.4",
    "@nuxt/schema": "^3.13.0",
    "@nuxt/test-utils": "^3.14.0",
    "@types/node": "^20.12.0",
    "h3": "^1.13.0",
    "nuxt": "^3.13.0",
    "typescript": "^5.5.0",
    "vue-tsc": "^2.1.0"
  }
}
