# ShowAd Next.js SDK - Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# PUBLIC VARIABLES (exposed to browser)
# ===========================================
# These use NEXT_PUBLIC_ prefix and are bundled into client-side JS

# Your creator hash from the ShowAd dashboard
# This is a unique identifier for your account
NEXT_PUBLIC_SHOWAD_CREATOR_HASH=your-creator-hash-here

# ShowAd Backend API URL
# Default: https://ad.proofmark.io
NEXT_PUBLIC_SHOWAD_API_URL=https://ad.proofmark.io

# ShowAd Video Ad Frontend URL
# Where users are redirected to watch video ads
# Default: https://showad.proofmark.io
NEXT_PUBLIC_SHOWAD_VIDEO_URL=https://showad.proofmark.io

# ===========================================
# PRIVATE VARIABLES (server-side only)
# ===========================================
# These do NOT have NEXT_PUBLIC_ prefix and stay on server

# Your API key from the ShowAd dashboard
# Format: sk-XXXXXXXXXXXXXXXX
# ⚠️ KEEP THIS SECRET - never expose to client!
SHOWAD_API_KEY=sk-your-api-key-here

# Redirect Ticket Secret
# Used for server-side ticket claiming
# Get this from your ShowAd dashboard
# ⚠️ KEEP THIS SECRET - never expose to client!
SHOWAD_REDIRECT_SECRET=your-redirect-secret-here

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================

# Enable debug mode (shows debug component and console logs)
# This is automatically enabled when NODE_ENV=development
# SHOWAD_DEBUG=true

