{
    "name": "proofmark/showad-laravel",
    "description": "ShowAd SDK for Laravel - Protect your content with video ad verification",
    "type": "library",
    "license": "MIT",
    "homepage": "https://proofmark.io",
    "support": {
        "source": "https://github.com/proofmark/proofmark/tree/main/sdks/laravel",
        "docs": "https://proofmark.io/docs"
    },
    "keywords": [
        "showad",
        "laravel",
        "sdk",
        "video-ads",
        "content-protection",
        "monetization",
        "proofmark"
    ],
    "authors": [
        {
            "name": "ProofMark",
            "email": "dev@proofmark.io"
        }
    ],
    "require": {
        "php": ">=8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/view": "^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "ProofMark\\ShowAd\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ProofMark\\ShowAd\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ProofMark\\ShowAd\\ShowAdServiceProvider"
            ],
            "aliases": {
                "ShowAd": "ProofMark\\ShowAd\\Facades\\ShowAd"
            }
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
