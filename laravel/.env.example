# ShowAd Creator Hash (from dashboard)
SHOWAD_CREATOR_HASH=your_creator_hash_here

# ShowAd API Key (secret - server-side only)
SHOWAD_API_KEY=sk-your-api-key-here

# ShowAd Redirect Secret (secret - server-side only)
SHOWAD_REDIRECT_SECRET=secret_your_redirect_secret_here

# ShowAd Backend API URL
SHOWAD_API_URL=https://ad.proofmark.io

# ShowAd Video Ad Frontend URL
SHOWAD_VIDEO_URL=https://showad.proofmark.io

# Cookie prefix (optional)
SHOWAD_COOKIE_PREFIX=showad

# Cookie max age in seconds (default: 3600 = 1 hour)
SHOWAD_COOKIE_MAX_AGE=3600

# Enable Inertia.js shared data (for Vue/React/Svelte starter kits)
SHOWAD_INERTIA_ENABLED=false

# Enable debug logging (null = follow APP_DEBUG)
SHOWAD_DEBUG=
